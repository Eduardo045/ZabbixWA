# Server
PORT=3000
NODE_ENV=production

# JWT Secret (change this to a long random string!)
JWT_SECRET=change-this-to-a-very-long-random-secret-string

# Webhook token (optional - set to require token auth on webhook)
WEBHOOK_TOKEN=

# Database path
DB_PATH=./data/zabbix-whatsapp.db

# Queue settings
QUEUE_INTERVAL_MS=5000
QUEUE_RATE_LIMIT=10
QUEUE_RATE_WINDOW_MS=60000
